  <Source dwd:design-time-name="e9c2ccc7-e168-4af5-a1d5-d28103edd66e">
    <DataSourceViewID>Sales</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="0d88b499-52db-4202-942e-9bd2dc5389b1">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].UnitPrice
 AS [Measures].[Total Price] / [Measures].[Qty], 
FORMAT_STRING = "Currency", 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
  <Kpis>
    <Kpi dwd:design-time-name="7c6ff876-4e51-4d1a-abc7-80b2eafec347">
      <ID>KPI</ID>
      <Name>QtyKPI</Name>
      <Value>[Measures].[Qty]</Value>
      <Goal>1000</Goal>
      <Status>CASE 
WHEN QtyKPI &gt; 1000 THEN 1
WHEN QtyKPI &lt; 1000 THEN 0
ELSE -1
END</Status>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Traffic Light</StatusGraphic>
    </Kpi>
  </Kpis>
</Cube>